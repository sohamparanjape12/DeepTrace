rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated and belongs to the specified org
    function isOrgMember(orgId) {
      return request.auth != null && 'org' in request.auth.token && request.auth.token.org == orgId;
    }

    // Rules for /organizations
    match /organizations/{orgId} {
      // Readable by owner and members
      allow read: if request.auth != null && (request.auth.uid == orgId || isOrgMember(orgId));
      // Allow updates for onboarding (setting legal name, DMCA attestation, etc)
      allow write: if request.auth != null && (request.auth.uid == orgId || isOrgMember(orgId));
    }

    // Rules for /assets
    match /assets/{assetId} {
      allow read: if request.auth != null && resource.data.owner_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.owner_id == request.auth.uid;
      // Lock down pipeline fields for updates
      allow update: if request.auth != null && resource.data.owner_id == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['stage', 'stage_updated_at', 'totals', 'idempotency']);
      allow delete: if request.auth != null && resource.data.owner_id == request.auth.uid;
    }

    // Rules for /violations 
    match /violations/{violationId} {
      allow read: if request.auth != null && resource.data.owner_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.owner_id == request.auth.uid;
      // Only allow updating status or specific UI fields
      allow update: if request.auth != null && resource.data.owner_id == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['stage', 'stage_updated_at', 'idempotency_key', 'attempts']);
      allow delete: if request.auth != null && resource.data.owner_id == request.auth.uid;
    }

    // Rules for /audit_log
    match /audit_log/{logId} {
      allow write: if false;
      allow read: if false; 
    }
    
    // Rules for /scans
    match /scans/{scanId} {
      allow write: if false; 
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/assets/$(resource.data.asset_id)).data.owner_id == request.auth.uid;
    }

    // Rules for /dmca_notices
    match /dmca_notices/{noticeId} {
      allow read: if request.auth != null && resource.data.customer_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.customer_id == request.auth.uid;
      allow update: if request.auth != null && resource.data.customer_id == request.auth.uid;
      allow delete: if false;
    }

    // Rules for /dmca_agent_cache
    match /dmca_agent_cache/{domain} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // or server only, but fine for MVP
    }

    // Rules for /whitelist
    match /whitelist/{itemId} {
      // Allow read for authenticated users (we still filter by owner_id in the query)
      allow read: if request.auth != null;
      // Allow create/delete if owner_id matches auth
      allow create: if request.auth != null && request.resource.data.owner_id == request.auth.uid;
      allow delete: if request.auth != null && resource.data.owner_id == request.auth.uid;
      allow update: if request.auth != null && resource.data.owner_id == request.auth.uid;
    }
  }
}
